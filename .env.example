# Copy to .env and fill in. Never commit the filled-in .env — it is gitignored.
# Every variable below is actually read by the code; nothing here is decorative.

# ---------------------------------------------------------------- database
# Prisma 7 reads this via prisma.config.ts, and .env is NOT auto-loaded —
# scripts do `import "dotenv/config"` themselves.
DATABASE_URL="postgresql://user:password@localhost:5432/planete_montessori_lms"

# ---------------------------------------------------------------- auth
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me"
# The site's own origin. Must be the public https URL in production.
AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------- links in e-mail
# Notification e-mails need absolute URLs. Falls back to AUTH_URL when unset,
# so only set this if the public URL differs from the auth origin.
# APP_URL="https://ecole.example.ma"

# ---------------------------------------------------------------- file storage
# "local" (default) or "s3". The s3 driver is an unimplemented stub that throws
# on write — on a VPS, keep local.
STORAGE_DRIVER="local"
# IMPORTANT in production: use an ABSOLUTE path OUTSIDE the deploy directory.
# The default "./storage" sits inside the app, so a deploy that replaces the
# directory (fresh clone, rsync --delete) destroys every uploaded justificatif,
# homework submission and student photo.
STORAGE_LOCAL_DIR="./storage"
# Only used when STORAGE_DRIVER=s3.
# S3_PUBLIC_URL="https://bucket.s3.example.com"

# ---------------------------------------------------------------- e-mail (SMTP)
# Leave SMTP_HOST empty to disable e-mail: notifications are then written and
# left PENDING rather than silently reported as sent.
SMTP_HOST=""
SMTP_PORT="587"           # 465 = implicit TLS; 587 = STARTTLS
SMTP_USER=""              # leave empty for an unauthenticated relay
SMTP_PASSWORD=""
SMTP_FROM="Ecole <no-reply@example.ma>"
